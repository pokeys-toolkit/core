			</aside>

			<!-- Main Content Area -->
			<main class="flex-1 p-8 min-h-screen">
				<div class="max-w-4xl">
					<!-- Header -->
					<div class="mb-12">
						<div class="flex items-center gap-4 mb-6">
							<span class="px-3 py-1 bg-pink-600/20 text-pink-300 text-sm rounded-full">LED Matrix</span>
						</div>
						<h1 class="text-4xl font-bold mb-4 bg-gradient-to-r from-pink-400 to-red-500 bg-clip-text text-transparent">
							LED Matrix API
						</h1>
						<p class="text-xl text-gray-400">
							LED matrix display control with configurable protocols and update mechanisms
						</p>
					</div>

					<!-- Overview -->
					<section class="mb-12">
						<h2 class="text-2xl font-bold mb-4 text-white">Overview</h2>
						<div class="bg-gray-800 rounded-lg p-6">
							<p class="text-gray-300 mb-4">
								The LED Matrix API provides control for LED matrix displays with configurable protocols and 
								efficient update mechanisms. Supports various matrix sizes and display patterns.
							</p>
						</div>
					</section>

					<!-- Configuration -->
					<section class="mb-12">
						<h2 class="text-2xl font-bold mb-6 text-white">Configuration</h2>
						<div class="bg-gray-800 rounded-lg p-6">
							<h3 class="text-xl font-semibold mb-4 text-pink-400">configure_led_matrix</h3>
							<div class="mb-4">
								<pre class="bg-gray-900 rounded p-4 overflow-x-auto"><code class="text-gray-300">pub fn configure_led_matrix(
    &mut self,
    config: &MatrixLedProtocolConfig,
) -> Result&lt;()&gt;</code></pre>
							</div>
							<p class="text-gray-300 mb-4">Configures LED matrix display protocol and parameters.</p>
						</div>
					</section>

					<!-- Display Update -->
					<section class="mb-12">
						<h2 class="text-2xl font-bold mb-6 text-white">Display Update</h2>
						<div class="bg-gray-800 rounded-lg p-6">
							<h3 class="text-xl font-semibold mb-4 text-pink-400">update_led_matrix</h3>
							<div class="mb-4">
								<pre class="bg-gray-900 rounded p-4 overflow-x-auto"><code class="text-gray-300">pub fn update_led_matrix(
    &mut self,
    matrix_id: u8,
    data: &[u8],
) -> Result&lt;()&gt;</code></pre>
							</div>
							<p class="text-gray-300 mb-4">Updates LED matrix display with new data.</p>
							<div class="bg-gray-900 rounded p-4">
								<h4 class="font-semibold text-yellow-400 mb-2">Example</h4>
								<pre class="text-gray-300"><code>// Update 8x8 LED matrix
let pattern = [
    0b11111111,
    0b10000001,
    0b10111101,
    0b10100101,
    0b10100101,
    0b10111101,
    0b10000001,
    0b11111111,
];

device.update_led_matrix(0, &pattern)?;</code></pre>
							</div>
						</div>
					</section>

					<!-- Best Practices -->
					<section class="mb-12">
						<h2 class="text-2xl font-bold mb-4 text-white">Best Practices</h2>
						<div class="bg-gray-800 rounded-lg p-6">
							<div class="space-y-4">
								<div>
									<h3 class="text-lg font-semibold mb-2 text-green-400">Performance</h3>
									<ul class="text-gray-300 space-y-1 text-sm">
										<li>• Update only when display content changes</li>
										<li>• Use efficient data formats for patterns</li>
										<li>• Consider refresh rate requirements</li>
									</ul>
								</div>
								<div>
									<h3 class="text-lg font-semibold mb-2 text-blue-400">Hardware</h3>
									<ul class="text-gray-300 space-y-1 text-sm">
										<li>• Ensure adequate current supply for LEDs</li>
										<li>• Use appropriate current limiting resistors</li>
										<li>• Consider multiplexing for large matrices</li>
									</ul>
								</div>
							</div>
						</div>
					</section>
				</div>
			</main>
		</div>
	</body>
</html>
