							<div class="bg-gray-900 rounded p-4">
								<pre class="text-gray-300"><code>match device.set_pin_function(1, PinFunction::DigitalOutput) {`{`}
    Ok(()) => println!(\"Pin configured successfully\"),
    Err(e) => eprintln!(\"Error: {`{`}:?{`}`}\", e),
{`}`}</code></pre>
							</div>
						</div>

						<div class="bg-gray-800 rounded-lg p-6 mb-6">
