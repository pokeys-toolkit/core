								<pre class="text-gray-300"><code>fn configure_device(device: &mut PoKeysDevice) -> Result&lt;()&gt; {`{`}
    device.set_pin_function(1, PinFunction::DigitalOutput)?;
    device.set_pin_function(2, PinFunction::DigitalInput)?;
    device.set_digital_output(1, true)?;
    Ok(())
{`}`}</code></pre>
							</div>
						</div>

						<div class="bg-gray-800 rounded-lg p-6">
							<h3 class="text-xl font-semibold mb-4 text-amber-400">Specific Error Handling</h3>
							<div class="bg-gray-900 rounded p-4">
								<pre class="text-gray-300"><code>match device.set_pin_function(22, PinFunction::PWM) {`{`}
    Ok(()) => {`{`}
        // Configure PWM settings
        device.set_pwm_period(500000)?;
        device.set_pwm_duty_cycle_for_pin(22, 25000)?;
    {`}`}
    Err(PoKeysError::UnsupportedCapability) => {`{`}
        println!(\"Pin 22 doesn't support PWM, using digital output\");
        device.set_pin_function(22, PinFunction::DigitalOutput)?;
    {`}`}
    Err(e) => return Err(e),
{`}`}</code></pre>
							</div>
						</div>
