								<h4 class="font-semibold text-yellow-400 mb-2">Retry with Fallback</h4>
								<pre class="text-gray-300"><code>fn robust_connection() -> Result&lt;PoKeysDevice&gt; {`{`}
    // Try USB first
    match enumerate_usb_devices() {`{`}
        Ok(count) if count > 0 => {`{`}
            return connect_to_device(0);
        {`}`}
        _ => {`{`} /* Continue to network */ {`}`}
    {`}`}
    
    // Fallback to network
    let devices = enumerate_network_devices(5000)?;
    if let Some(device_info) = devices.first() {`{`}
        connect_to_network_device(device_info)
    {`}`} else {`{`}
        Err(PoKeysError::DeviceNotFound)
    {`}`}
{`}`}</code></pre>
							</div>
						</div>
