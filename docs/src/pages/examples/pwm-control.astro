					<h2 class="text-2xl font-bold mb-4 text-white">LED Dimming Example</h2>
					<div class="bg-gray-800 rounded-lg p-6">
						<pre class="bg-gray-900 p-4 rounded-lg overflow-x-auto"><code class="text-green-400">use pokeys_lib::*;
use std::&#123;thread, time::Duration&#125;;

fn main() -&gt; Result&lt;(), Box&lt;dyn std::error::Error&gt;&gt; &#123;
    println!("⚡ PoKeys PWM Control Example");
    println!("============================");

    // Connect to device
    let device_count = enumerate_usb_devices()?;
    if device_count == 0 &#123;
        println!("❌ No PoKeys devices found!");
        return Ok(());
    &#125;

    let mut device = connect_to_device(0)?;
    println!("✅ Connected to: &#123;&#125;", device.get_device_name()?);

    // Configure pin 4 for PWM output
    println!("⚙️  Configuring pin 4 for PWM...");
    device.set_pin_function(4, PinFunction::PWMOutput)?;

    // Set PWM frequency to 1kHz (good for LEDs)
    device.set_pwm_frequency(4, 1000.0)?;
    println!("✅ PWM configured at 1kHz");

    // Demonstrate different PWM techniques
    fade_in_out(&mut device)?;
    breathing_effect(&mut device)?;
    step_control(&mut device)?;

    // Turn off PWM
    device.set_pwm_duty_cycle(4, 0.0)?;
    println!("🎉 PWM example completed!");

    Ok(())
&#125;

/// Smooth fade in and fade out effect
fn fade_in_out(device: &mut Device) -&gt; Result&lt;(), Box&lt;dyn std::error::Error&gt;&gt; &#123;
    println!("💡 Demonstrating fade in/out...");

    // Fade in (0% to 100%)
    for duty in (0..=100).step_by(2) &#123;
        device.set_pwm_duty_cycle(4, duty as f32)?;
        thread::sleep(Duration::from_millis(50));
    &#125;

    thread::sleep(Duration::from_millis(500));

    // Fade out (100% to 0%)
    for duty in (0..=100).rev().step_by(2) &#123;
        device.set_pwm_duty_cycle(4, duty as f32)?;
        thread::sleep(Duration::from_millis(50));
    &#125;

    thread::sleep(Duration::from_millis(500));
    Ok(())
&#125;

/// Breathing effect using sine wave
fn breathing_effect(device: &mut Device) -&gt; Result&lt;(), Box&lt;dyn std::error::Error&gt;&gt; &#123;
    println!("🫁 Demonstrating breathing effect...");

    for i in 0..200 &#123;
        let angle = (i as f32) * 0.1;
        let duty = 50.0 + 45.0 * angle.sin(); // 5% to 95%
        device.set_pwm_duty_cycle(4, duty)?;
        thread::sleep(Duration::from_millis(25));
    &#125;

    Ok(())
&#125;

/// Step-wise control demonstration
fn step_control(device: &mut Device) -&gt; Result&lt;(), Box&lt;dyn std::error::Error&gt;&gt; &#123;
    println!("📊 Demonstrating step control...");

    let steps = [10.0, 25.0, 50.0, 75.0, 100.0, 75.0, 50.0, 25.0];

    for &duty in &steps &#123;
        println!("   Setting duty cycle to &#123;&#125;%", duty);
        device.set_pwm_duty_cycle(4, duty)?;
        thread::sleep(Duration::from_millis(800));
    &#125;

    Ok(())
&#125;</code></pre>
