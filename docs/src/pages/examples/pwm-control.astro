					<div class="bg-gray-800 rounded-lg p-6">
						<div class="bg-yellow-900/20 border border-yellow-500/30 rounded-lg p-4 mb-4">
							<p class="text-yellow-300 text-sm">
								⚠️ <strong>Warning:</strong> Never connect motors directly to PoKeys pins. Always use appropriate motor drivers or MOSFETs.
							</p>
						</div>
						<pre class="bg-gray-900 p-4 rounded-lg overflow-x-auto"><code class="text-green-400">use pokeys_lib::*;
use std::&#123;thread, time::Duration&#125;;

fn motor_speed_control() -&gt; Result&lt;(), Box&lt;dyn std::error::Error&gt;&gt; &#123;
    let mut device = connect_to_device(0)?;

    // Configure pin for motor PWM (connected to motor driver)
    device.set_pin_function(5, PinFunction::PWMOutput)?;

    // Set higher frequency for motors (10kHz reduces audible noise)
    device.set_pwm_frequency(5, 10000.0)?;

    println!("🏃 Motor speed control demo");

    // Gradual acceleration
    println!("⬆️  Accelerating...");
    for speed in (0..=80).step_by(5) &#123;
        device.set_pwm_duty_cycle(5, speed as f32)?;
        println!("   Speed: &#123;&#125;%", speed);
        thread::sleep(Duration::from_millis(300));
    &#125;

    // Hold at 80% for 2 seconds
    thread::sleep(Duration::from_secs(2));

    // Gradual deceleration
    println!("⬇️  Decelerating...");
    for speed in (0..=80).rev().step_by(5) &#123;
        device.set_pwm_duty_cycle(5, speed as f32)?;
        println!("   Speed: &#123;&#125;%", speed);
        thread::sleep(Duration::from_millis(200));
    &#125;

    println!("🛑 Motor stopped");
    Ok(())
&#125;</code></pre>
