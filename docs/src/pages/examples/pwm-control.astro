device.set_pin_function(4, PinFunction::PWMOutput)?;
device.set_pin_function(5, PinFunction::PWMOutput)?;
device.set_pin_function(6, PinFunction::PWMOutput)?;

// RGB LED control
device.set_pwm_duty_cycle(4, 100.0)?; // Red channel
device.set_pwm_duty_cycle(5, 50.0)?;  // Green channel
