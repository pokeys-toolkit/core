// Synchronized PWM for 3-phase motor control
device.set_pwm_frequency(4, 20000.0)?;
device.set_pwm_frequency(5, 20000.0)?;
device.set_pwm_frequency(6, 20000.0)?;

// Phase-shifted PWM (120° apart for 3-phase)
device.set_pwm_duty_cycle(4, 50.0)?;
device.set_pwm_duty_cycle(5, 50.0)?;
device.set_pwm_duty_cycle(6, 50.0)?;</code></pre>
