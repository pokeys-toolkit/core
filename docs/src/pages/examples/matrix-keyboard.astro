						<pre class="p-4 overflow-x-auto"><code id="code-example" class="text-sm">use pokeys_lib::*;
use std::thread;
use std::time::Duration;

fn main() -> Result<()> {
    println!("🎹 PoKeys Matrix Keyboard Example");
    println!("=================================");

    // Connect to first available device
    let mut device = match connect_to_first_available_device() {
        Ok(device) => device,
        Err(e) => {
            println!("❌ No PoKeys device found: {}", e);
            return Ok(());
        }
    };

    println!("✅ Connected to device (Serial: {})", device.device_data.serial_number);

    // Configure 4x4 matrix keyboard
    let width = 4;
    let height = 4;
    let column_pins = [5, 6, 7, 8];  // Pins 5-8 for columns
    let row_pins = [1, 2, 3, 4];    // Pins 1-4 for rows

    println!("🔧 Configuring {}x{} matrix keyboard...", width, height);
    device.configure_matrix_keyboard(width, height, &column_pins, &row_pins)?;
    println!("✅ Matrix keyboard configured successfully!");

    // Display keyboard layout
    display_keyboard_layout(width, height);

    // Monitor keyboard for key presses
    println!("🔍 Monitoring keyboard (press Ctrl+C to exit)...");
    let mut previous_states = vec![vec![false; width as usize]; height as usize];
    let mut key_press_count = 0;

    loop {
        // Read current keyboard state
        device.read_matrix_keyboard()?;

        // Check for state changes
        let mut state_changed = false;
        for row in 0..height as usize {
            for col in 0..width as usize {
                let current_state = device.matrix_keyboard.get_key_state(row, col);
                let previous_state = previous_states[row][col];

                if current_state != previous_state {
                    state_changed = true;
                    if current_state {
                        key_press_count += 1;
                        println!("🔴 Key PRESSED  at ({}, {}) - Key #{}", row, col, key_press_count);
                    } else {
                        println!("🔵 Key RELEASED at ({}, {})", row, col);
                    }
                    previous_states[row][col] = current_state;
                }
            }
        }

        // Display current state if changed
        if state_changed {
            display_current_state(&device, width, height);
        }

        thread::sleep(Duration::from_millis(50));
    }
}

fn connect_to_first_available_device() -> Result<PoKeysDevice> {
    // Try network devices first
    match enumerate_network_devices(2000) {
        Ok(devices) if !devices.is_empty() => {
            return connect_to_network_device(&devices[0]);
        }
        _ => {}
    }

    // Try USB devices
    match enumerate_usb_devices() {
        Ok(count) if count > 0 => connect_to_device(0),
        _ => Err(PoKeysError::DeviceNotFound),
    }
}

fn display_keyboard_layout(width: u8, height: u8) {
    println!("\n📋 Keyboard Layout ({}x{}):", width, height);
    println!("   ┌─────┬─────┬─────┬─────┐");
    
    for row in 0..height {
        print!("   │");
        for col in 0..width {
            print!(" {:>2},{} │", row, col);
        }
        println!();
        
        if row < height - 1 {
            println!("   ├─────┼─────┼─────┼─────┤");
        }
    }
    
    println!("   └─────┴─────┴─────┴─────┘");
}

fn display_current_state(device: &PoKeysDevice, width: u8, height: u8) {
    println!("\n📊 Current Keyboard State:");
    println!("   ┌─────┬─────┬─────┬─────┐");
    
    for row in 0..height {
        print!("   │");
        for col in 0..width {
            let pressed = device.matrix_keyboard.get_key_state(row as usize, col as usize);
            let symbol = if pressed { " ███ " } else { "     " };
            print!("{}│", symbol);
        }
        println!();
        
        if row < height - 1 {
            println!("   ├─────┼─────┼─────┼─────┤");
        }
    }
    
    println!("   └─────┴─────┴─────┴─────┘");
    println!("   ███ = pressed, blank = released");
}</code></pre>
